{
  "version": 1,
  "author": "office-monitor-project",
  "editor": "wokwi",
  "parts": [
    { "type": "wokwi-esp32-devkit-v1", "id": "esp", "top": 0, "left": 0, "attrs": {} },

    { "type": "wokwi-resistor", "id": "r_light1", "top": -80, "left": 200, "attrs": { "value": "220" } },
    { "type": "wokwi-led", "id": "light1", "top": -110, "left": 230, "attrs": { "color": "yellow", "label": "Light 1" } },

    { "type": "wokwi-resistor", "id": "r_light2", "top": -30, "left": 200, "attrs": { "value": "220" } },
    { "type": "wokwi-led", "id": "light2", "top": -60, "left": 230, "attrs": { "color": "yellow", "label": "Light 2" } },

    { "type": "wokwi-resistor", "id": "r_light3", "top": 20, "left": 200, "attrs": { "value": "220" } },
    { "type": "wokwi-led", "id": "light3", "top": -10, "left": 230, "attrs": { "color": "yellow", "label": "Light 3" } },

    { "type": "wokwi-resistor", "id": "r_fan1", "top": 70, "left": 200, "attrs": { "value": "220" } },
    { "type": "wokwi-led", "id": "fan1", "top": 40, "left": 230, "attrs": { "color": "cyan", "label": "Fan 1" } },

    { "type": "wokwi-resistor", "id": "r_fan2", "top": 120, "left": 200, "attrs": { "value": "220" } },
    { "type": "wokwi-led", "id": "fan2", "top": 90, "left": 230, "attrs": { "color": "cyan", "label": "Fan 2" } },

    { "type": "wokwi-ntc-temperature-sensor", "id": "acs712_stand_in", "top": 150, "left": 40, "attrs": { "label": "ACS712 current sensor (analog stand-in)" } }
  ],
  "connections": [
    [ "esp:D16", "r_light1:1", "black", [] ],
    [ "r_light1:2", "light1:A", "black", [] ],
    [ "light1:C", "esp:GND.1", "black", [] ],

    [ "esp:D17", "r_light2:1", "black", [] ],
    [ "r_light2:2", "light2:A", "black", [] ],
    [ "light2:C", "esp:GND.1", "black", [] ],

    [ "esp:D18", "r_light3:1", "black", [] ],
    [ "r_light3:2", "light3:A", "black", [] ],
    [ "light3:C", "esp:GND.1", "black", [] ],

    [ "esp:D19", "r_fan1:1", "black", [] ],
    [ "r_fan1:2", "fan1:A", "black", [] ],
    [ "fan1:C", "esp:GND.1", "black", [] ],

    [ "esp:D21", "r_fan2:1", "black", [] ],
    [ "r_fan2:2", "fan2:A", "black", [] ],
    [ "fan2:C", "esp:GND.1", "black", [] ],

    [ "esp:D34", "acs712_stand_in:SIG", "green", [] ],
    [ "acs712_stand_in:VCC", "esp:3V3", "red", [] ],
    [ "acs712_stand_in:GND", "esp:GND.2", "black", [] ]
  ]
}
